# OpenRouter API Token (Recommended - Fast & Cheap)
# Get your token from: https://openrouter.ai/keys
# Cost: ~$0.001 per request with DeepSeek model
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# HuggingFace API Token (Optional - for local model)
# Get your token from: https://huggingface.co/settings/tokens
# Only needed if using local model (slow on CPU)
HF_TOKEN=hf_your_token_here
